{
    "name": "vielhuber/memhelper",
    "description": "Markdown-first memory layer for LLM agents — one call, transparent indexing and auto-extraction.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "symfony/yaml": "^7.0",
        "vielhuber/aihelper": "*",
        "vielhuber/dbhelper": "*"
    },
    "suggest": {
        "ext-pdo_sqlite": "Required for the internal FTS5 search index",
        "ext-zip": "Required to index .docx and .xlsx attachments",
        "poppler-utils": "Provides pdftotext for indexing PDFs"
    },
    "autoload": {
        "psr-4": {
            "vielhuber\\memhelper\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13"
    },
    "bin": [
        "bin/memhelper-worker"
    ]
}
