{
    "name": "vielhuber/memhelper",
    "description": "Markdown-first memory layer for LLM agents \u2014 one call, transparent indexing and auto-extraction.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "symfony/yaml": "^8.1.0",
        "vielhuber/aihelper": "^3.7.1",
        "vielhuber/dbhelper": "^2.5.0",
        "vielhuber/simplemcp": "^1.1.4"
    },
    "suggest": {
        "ext-pdo_sqlite": "Required for the internal FTS5 search index",
        "ext-zip": "Required to index .docx and .xlsx attachments",
        "poppler-utils": "Provides pdftotext for indexing PDFs"
    },
    "autoload": {
        "psr-4": {
            "vielhuber\\memhelper\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13"
    },
    "bin": [
        "bin/memhelper-worker",
        "src/mcp-server.php"
    ]
}